# ============================================================
# Rating Microservice — Environment Configuration
# ============================================================
# Copy this file to .env and adjust values for your environment.
# cp .env.example .env

# --- Execution Mode ---
EXECUTION_MODE=LOCAL

# --- Database ---
# SQLite (default for local development):
DATABASE_URL=sqlite+aiosqlite:///./rating.db

# MSSQL (for Docker / Production):
# MSSQL_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=tcp:localhost,1433;Database=rating;Uid=sa;Pwd={YourPassword};Encrypt=no;TrustServerCertificate=yes;

# --- Service Ports ---
PORT=8012

# --- Inter-Service URLs ---
# Qualification MS (if integrated):
# QUALIFICATION_SERVICE_URL=http://localhost:8013

# --- Frontend ---
FRONTEND_URL=http://localhost:3000
